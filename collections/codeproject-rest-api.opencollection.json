            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.codeproject.com/v1/ForumMessages/:forumId",
            "params": [
              {
                "name": "forumId",
                "value": "",
                "type": "path"
              },
              {
                "name": "page",
                "value": "",
                "type": "query"
              }
            ]
          },
          "docs": "List the latest messages for a forum"
        }
      ]
    },
    {
      "info": {
        "name": "Questions",
